# ================================
# Delycia Docker Environment Variables
# Copy to .env.docker and fill in your values
# ================================

# ================================
# Ports (optional - defaults shown)
# ================================
SERVER_PORT=8020
CLIENT_PORT=4000
ADMIN_PORT=4500

# ================================
# Database Configuration
# ================================
DB_HOST=your-database-host
DB_USER=your-database-user
DB_NAME=your-database-name
DB_PASS=your-database-password

# ================================
# Server Secrets
# ================================
ACCESS_SECRET=your-access-secret
REFRESH_SECRET=your-refresh-secret
HMAC_SECRECT=your-hmac-secret

# ================================
# External APIs
# ================================
GEMINI_API_KEY=your-gemini-api-key

# ================================
# CORS Configuration
# ================================
ORIGIN=*
SSL=false

# ================================
# Twilio (SMS)
# ================================
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token

# ================================
# Client & Admin API URLs
# For Docker internal communication, use service names:
# - http://server:8020/api/v1 (inside Docker network)
# For external access, use your public URL:
# - https://api.yourdomain.com/api/v1
# ================================
VITE_API_BASE_URL=http://server:8020/api/v1
ADMIN_SERVER_URL=http://server:8020/api/v1
WS_SERVER_URL=ws://server:8020/orders

# ================================
# Email (Resend)
# ================================
RESEND_API_KEY=your-resend-api-key

# ================================
# Google OAuth
# ================================
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ================================
# ImageKit (Image Storage)
# ================================
IMAGEKIT_PUBLIC_URL_ENDPOINT=https://ik.imagekit.io/your-id
IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key
NEXT_PUBLIC_IMAGEKIT_PUBLIC_KEY=your-imagekit-public-key
IMAGEKIT_PRIVATE_KEY=your-imagekit-private-key

# ================================
# Admin Crypto
# ================================
CRYPTO_SECRET_KEY=your-crypto-secret-key
