# Environment Variables Template
# Copy this file to .env for development or .env.production for production

# Database (Dokploy / MariaDB)
DB_HOST=your_db_host
DB_PORT=3306
DB_NAME=your_db_name
DB_USER=your_db_user
DB_PASS=your_db_password
DB_DIALECT=mariadb

# Redis Configs
# Development: redis://localhost:6379
# Production: redis://your_vps_ip:6379
REDIS_URL=redis://localhost:6379

#Server PORT
PORT=8020

#Others
ACCESS_SECRET=your_access_secret
REFRESH_SECRET=your_refresh_secret
HMAC_SECRECT=your_hmac_secret
GEMINI_API_KEY=your_gemini_api_key

#CORS
ORIGIN=*
SSL=false
# Comma-separated list of extra allowed origins (e.g. your Vercel frontend URL)
# Example: ALLOWED_ORIGINS=https://delycia.vercel.app,https://admin.delycia.com
ALLOWED_ORIGINS=

# MSG91 WhatsApp API
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_INTEGRATED_NUMBER=your_phone_number
MSG91_TEMPLATE_NAMESPACE=your_template_namespace
MSG91_TEMPLATE_NAME=your_template_name

# Magic Link Configuration
MAGIC_LINK_BASE_URL=http://localhost:4000

MAGIC_LINK_EXPIRY_MINUTES=5

# CSRF Protection
CSRF_SECRET=your_csrf_secret

# Vercel (auto-set by Vercel runtime — do NOT set manually)
# VERCEL=1
