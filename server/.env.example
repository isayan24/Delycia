# Production Environment Variables
# This file is used in production deployment

# Database (Dokploy / MariaDB)
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=your_database_name
DB_USER=your_db_user
DB_PASS=your_secure_db_password
DB_DIALECT=mariadb

# Redis Configs (Production - Hosted Redis)
REDIS_URL=redis://your-redis-host:6379

# Server PORT
PORT=8020

# Others
ACCESS_SECRET=your_access_token_secret_string
REFRESH_SECRET=your_refresh_token_secret_string
HMAC_SECRECT=your_hmac_secret_string
GEMINI_API_KEY=AIzaSy_Sample_API_Key_1234567890

# CORS
ORIGIN=*
SSL=true

# MSG91 WhatsApp
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_INTEGRATED_NUMBER=1234567890
MSG91_TEMPLATE_NAMESPACE=your_namespace_id
MSG91_TEMPLATE_NAME=your_template_name

# Magic Link Configuration
MAGIC_LINK_BASE_URL=https://your-app-domain.com
MAGIC_LINK_EXPIRY_MINUTES=5

# CSRF Protection
CSRF_SECRET=a7f3c8e9d2b4f6a1c5e8d9b3f7a2c6e4d8b1f5a9c3e7d2b6f4a8c1e5d9b